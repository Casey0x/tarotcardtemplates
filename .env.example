# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — server-only, for studio/auth
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Templated.io — server-only, never in frontend
TEMPLATED_API_KEY=

# Supabase: create a Storage bucket named "card-artwork" (public) for studio uploads.

# Site URL (e.g. https://tarotcardtemplates.com) for Stripe redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics (optional — gtag loads when set)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
