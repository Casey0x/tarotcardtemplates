# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — server-only, for studio/auth
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Templated.io — server-only, never in frontend
TEMPLATED_API_KEY=

# Supabase: create a Storage bucket named "card-artwork" (public) for studio uploads.

# Site URL (e.g. https://tarotcardtemplates.com) for Stripe redirects / Studio export
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional alias (e.g. https://www.tarotcardtemplates.com) — used if NEXT_PUBLIC_SITE_URL is unset
NEXT_PUBLIC_BASE_URL=

# Google Analytics (optional — gtag loads when set)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Resend (server-only — transactional email; EMAIL_REPLY_TO = team inbox + Reply-To on customer mail)
RESEND_API_KEY=
EMAIL_FROM=no-reply@tarotcardtemplates.com
EMAIL_REPLY_TO=casey@tarotcardtemplates.com
